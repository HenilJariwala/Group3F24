@page "/register"
@using TrackWiseFrontend.Model
@inject NavigationManager Navigation

<div class="register-container">
    <h2 class="app-title">Track-Wise</h2>
    <h3 class="create-account-title">Create Account</h3>

    <EditForm Model="RegisterModel" OnValidSubmit="HandleRegistration">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="input-container">
            <InputText id="Email" placeholder="Enter your Email" class="input-field" @bind-Value="RegisterModel.Email" />
            <ValidationMessage For="@(() => RegisterModel.Email)" />
        </div>

        <div class="input-container">
            <InputText id="Username" placeholder="Enter the Username" class="input-field" @bind-Value="RegisterModel.Username" />
            <ValidationMessage For="@(() => RegisterModel.Username)" />
        </div>

        <div class="input-container">
            <InputText id="Password" type="password" placeholder="Enter the Password" class="input-field" @bind-Value="RegisterModel.Password" />
            <ValidationMessage For="@(() => RegisterModel.Password)" />
        </div>

        <div class="input-container">
            <InputText id="ConfirmPassword" type="password" placeholder="Re-enter Password" class="input-field" @bind-Value="RegisterModel.ConfirmPassword" />
            <ValidationMessage For="@(() => RegisterModel.ConfirmPassword)" />
        </div>

        <button type="submit" class="btn-submit">Create</button>

        <div class="or-divider">Or</div>

        <button type="button" class="btn-social google">
            <img src="google-icon.png" alt="Google Icon" class="social-icon" />
            Sign up with Google
        </button>
        <button type="button" class="btn-social facebook">
            <img src="facebook-icon.png" alt="Facebook Icon" class="social-icon" />
            Sign up with Facebook
        </button>
    </EditForm>
</div>

<style>
    .register-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: #1c2a39;
        padding: 20px;
        border-radius: 10px;
        width: 100%;
        max-width: 400px;
        margin: auto;
        color: #fff;
    }

    .app-title {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .create-account-title {
        font-size: 24px;
        margin-bottom: 20px;
    }

    .input-container {
        width: 100%;
        margin-bottom: 15px;
    }

    .input-field {
        width: 100%;
        padding: 10px;
        border-radius: 5px;
        border: none;
        outline: none;
        background-color: #4a6075;
        color: #fff;
        font-size: 16px;
    }

    .btn-submit {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        background-color: #6fa3ef;
        color: #fff;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 18px;
    }

    .btn-submit:hover {
        background-color: #5c8cda;
    }

    .or-divider {
        margin: 20px 0;
        color: #aaa;
    }

    .btn-social {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        background-color: #3b5998;
        color: #fff;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }

    .btn-social.google {
        background-color: #db4437;
    }

    .btn-social.facebook {
        background-color: #3b5998;
    }

    .btn-social img {
        width: 20px;
        height: 20px;
        margin-right: 10px;
    }
</style>

@code {
    private RegisterModel RegisterModel = new RegisterModel();

    private async Task HandleRegistration()
    {
        await Task.Delay(1000);
        Console.WriteLine("Registration Attempted");
        Navigation.NavigateTo("/dashboard");
    }
}
